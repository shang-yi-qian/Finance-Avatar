# ── OpenAI ──────────────────────────────────────────────
# Used by: orchestrator, all subagents, GPT Image 2, GPT Realtime 2
OPENAI_API_KEY=sk-...

# ── ElevenLabs ───────────────────────────────────────────
# Used by: voice clone (onboarding), TTS per pitch, optional LipSync API
ELEVENLABS_API_KEY=...
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# Real cloned-voice TTS is used by default when a non-mock voice_id exists.
ELEVENLABS_LIVE_TTS=true
ELEVENLABS_FORCE_MOCK_TTS=false

# ── Avatar Generation ────────────────────────────────────
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_REASONING_MODEL=gpt-5.5
OPENAI_TIMEOUT=30
OPENAI_TRANSCRIBE_TIMEOUT=25
OPENAI_LINGO_TIMEOUT=20
OPENAI_IMAGE_RESPONSES_TIMEOUT=90
OPENAI_IMAGE_EDIT_TIMEOUT=60
OPENAI_IMAGE_GENERATE_TIMEOUT=60
ELEVENLABS_CLONE_TIMEOUT=35
ELEVENLABS_TTS_TIMEOUT=25

# ── Exa ─────────────────────────────────────────────────
# Used by: research subagent (7-day news, earnings sentiment, analyst tone)
EXA_API_KEY=...

# ── Adaption (Adaptive Data) ─────────────────────────────
# Used by: user style profile get/update, personalization loop
ADAPTION_API_KEY=...

# ── Smithery MCP ─────────────────────────────────────────
# Used by: valuation subagent — tries Smithery Connect first, falls back to direct FMP
SMITHERY_API_KEY=...
SMITHERY_NAMESPACE=your-smithery-username
SMITHERY_MARKET_CONNECTION_ID=cfocoder-financial-modeling-prep-mcp-server
SMITHERY_SHIBUI_CONNECTION_ID=finance

# ── FMP (Financial Modeling Prep) ────────────────────────
# Used by: valuation subagent direct fallback when Smithery cannot pass the token
# Also required by the Smithery FMP connectors (if they ever work with token passthrough)
FMP_ACCESS_TOKEN=...

# ── Convex ───────────────────────────────────────────────
# Run `npx convex dev` in frontend/ to get these values
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:...

# ── Frontend (Vite exposes VITE_ vars to browser) ────────
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_API_BASE_URL=http://localhost:8000

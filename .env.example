# ── OpenAI ──────────────────────────────────────────────
# Used by: orchestrator, all subagents, GPT Image 2, GPT Realtime 2
OPENAI_API_KEY=sk-...

# ── ElevenLabs ───────────────────────────────────────────
# Used by: voice clone (onboarding), TTS per pitch, optional LipSync API
ELEVENLABS_API_KEY=...

# ── Exa ─────────────────────────────────────────────────
# Used by: research subagent (7-day news, earnings sentiment, analyst tone)
EXA_API_KEY=...

# ── Adaption (Adaptive Data) ─────────────────────────────
# Used by: user style profile get/update, personalization loop
ADAPTION_API_KEY=...

# ── Smithery MCP ─────────────────────────────────────────
# Used by: valuation subagent (price, P/E, EPS, beta, consensus)
SMITHERY_API_KEY=...

# ── Convex ───────────────────────────────────────────────
# Run `npx convex dev` in frontend/ to get these values
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:...

# ── Frontend (Vite exposes VITE_ vars to browser) ────────
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_API_BASE_URL=http://localhost:8000
